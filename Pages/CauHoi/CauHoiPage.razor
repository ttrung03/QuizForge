@page "/cauhoi"
@using MudBlazor
@using QuestionBank.Web.Application.DTOs
@using QuestionBank.Web.Application.Services
@using QuestionBank.Web.Components.Shared
@inject CauHoiService CauHoiService
@inject MonHocService MonHocService
@inject PhanService PhanService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Quản lý Câu hỏi</PageTitle>

@* ── Header ── *@
<div class="d-flex align-center justify-space-between mb-4 flex-wrap gap-2">
    <div class="d-flex align-center gap-2">
        <MudIcon Icon="@Icons.Material.Filled.Quiz" Color="Color.Primary" Size="Size.Large" />
        <div>
            <MudText Typo="Typo.h5" Style="font-weight:700;line-height:1.2">Ngân hàng Câu hỏi</MudText>
            <MudText Typo="Typo.caption" Class="mud-text-secondary">Duyệt, import và quản lý câu hỏi trắc nghiệm</MudText>
        </div>
    </div>
    <div class="d-flex gap-2">
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Secondary"
                   StartIcon="@Icons.Material.Filled.PermMedia"
                   OnClick="OpenMediaDialog"
                   Size="Size.Small">
            Media
        </MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Upload"
                   Disabled="@(_maPhan == Guid.Empty)"
                   OnClick="OpenImportDialog"
                   Size="Size.Small">
            Import câu hỏi
        </MudButton>
    </div>
</div>

@* ── Filter panel ── *@
<MudPaper Elevation="1" Class="pa-4 mb-4 rounded-lg">
    <MudText Typo="Typo.subtitle2" Class="mb-3 mud-text-secondary" Style="text-transform:uppercase;letter-spacing:.05em;font-size:.7rem">
        Bộ lọc
    </MudText>
    <MudGrid Spacing="2" AlignItems="Center">
        <MudItem xs="12" sm="5">
            <MudSelect T="Guid"
                       Value="_maMonHoc"
                       ValueChanged="OnMonHocChanged"
                       Label="Môn học"
                       Variant="Variant.Outlined"
                       Clearable="true"
                       AdornmentIcon="@Icons.Material.Outlined.Book"
                       Adornment="Adornment.Start"
                       Dense="true">
                @foreach (var mh in _monHocList)
                {
                    <MudSelectItem Value="@mh.MaMonHoc">@mh.TenMonHoc</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="5">
            <MudSelect T="Guid"
                       Value="_maPhan"
                       ValueChanged="OnPhanChanged"
                       Label="Phần / Chương"
                       Variant="Variant.Outlined"
                       Clearable="true"
                       AdornmentIcon="@Icons.Material.Outlined.AccountTree"
                       Adornment="Adornment.Start"
                       Dense="true"
                       Disabled="@(_maMonHoc == Guid.Empty)">
                @foreach (var p in _phanList)
                {
                    <MudSelectItem Value="@p.MaPhan">@p.TenPhan</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="2">
            <MudTextField @bind-Value="_searchText"
                          Label="Tìm kiếm"
                          Variant="Variant.Outlined"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Clearable="true"
                          Dense="true"
                          Disabled="@(_maPhan == Guid.Empty)" />
        </MudItem>
    </MudGrid>

    @if (_maPhan != Guid.Empty && _questions.Count > 0)
    {
        <div class="d-flex align-center gap-2 mt-3 flex-wrap">
            <MudText Typo="Typo.caption" Class="mud-text-secondary">Độ khó:</MudText>
            <MudChip T="string" Size="Size.Small"
                     Color="@(_filterCapDo == 0 ? Color.Primary : Color.Default)"
                     OnClick="@(() => SetFilter(0))">Tất cả</MudChip>
            <MudChip T="string" Size="Size.Small"
                     Color="@(_filterCapDo == 1 ? Color.Success : Color.Default)"
                     OnClick="@(() => SetFilter(1))">Dễ</MudChip>
            <MudChip T="string" Size="Size.Small"
                     Color="@(_filterCapDo == 2 ? Color.Warning : Color.Default)"
                     OnClick="@(() => SetFilter(2))">Trung bình</MudChip>
            <MudChip T="string" Size="Size.Small"
                     Color="@(_filterCapDo == 3 ? Color.Error : Color.Default)"
                     OnClick="@(() => SetFilter(3))">Khó</MudChip>
        </div>
    }
</MudPaper>

@* ── Content ── *@
@if (_maPhan == Guid.Empty)
{
    <MudPaper Elevation="0" Class="d-flex flex-column align-center justify-center pa-10 rounded-lg"
              Style="border:2px dashed var(--mud-palette-divider);background:transparent">
        <MudIcon Icon="@Icons.Material.Outlined.FilterList" Size="Size.Large" Color="Color.Default" Style="opacity:.4" />
        <MudText Typo="Typo.h6" Class="mt-3" Style="opacity:.6">Chọn Môn học và Phần</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mt-1">
            Dùng bộ lọc phía trên để chọn môn học và phần cần xem.
        </MudText>
    </MudPaper>
}
else if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Rounded="true" Class="mb-2" />
    <MudText Typo="Typo.caption" Class="mud-text-secondary d-flex justify-center">Đang tải câu hỏi...</MudText>
}
else if (FilteredSingles.Count == 0 && FilteredGroups.Count == 0)
{
    <MudPaper Elevation="0" Class="d-flex flex-column align-center justify-center pa-10 rounded-lg"
              Style="border:2px dashed var(--mud-palette-divider);background:transparent">
        <MudIcon Icon="@Icons.Material.Outlined.Quiz" Size="Size.Large" Color="Color.Default" Style="opacity:.4" />
        <MudText Typo="Typo.h6" Class="mt-3" Style="opacity:.6">
            @(_questions.Count == 0 ? "Chưa có câu hỏi nào" : "Không tìm thấy kết quả")
        </MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mt-1">
            @(_questions.Count == 0
                ? "Import câu hỏi từ file Word hoặc Excel để bắt đầu."
                : "Thử thay đổi từ khóa hoặc bộ lọc độ khó.")
        </MudText>
        @if (_questions.Count == 0)
        {
            <MudButton Class="mt-4" Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Upload"
                       OnClick="OpenImportDialog">
                Import ngay
            </MudButton>
        }
    </MudPaper>
}
else
{
    @* ── Summary bar ── *@
    <div class="d-flex align-center justify-space-between mb-3 flex-wrap gap-2">
        <MudText Typo="Typo.body2" Class="mud-text-secondary">
            Hiển thị <b>@(FilteredSingles.Count + FilteredGroups.Count)</b> /
            @(_questions.Where(q => !q.LaCauNhom).Count() + _questions.Where(q => q.LaCauNhom).Count()) mục
            @if (_questions.Count > 0)
            {
                var s = _questions.Where(q => !q.LaCauNhom).ToList();
                var g = _questions.Where(q =>  q.LaCauNhom).ToList();
                <span> &nbsp;·&nbsp; @s.Count câu đơn · @g.Count nhóm (@g.Sum(x => x.SoCauHoiCon) câu con)</span>
            }
        </MudText>
        <div class="d-flex gap-1">
            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">
                Dễ: @_questions.Count(q => q.CapDo == 1 && !q.LaCauNhom)
            </MudChip>
            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">
                TB: @_questions.Count(q => q.CapDo == 2 && !q.LaCauNhom)
            </MudChip>
            <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined">
                Khó: @_questions.Count(q => q.CapDo == 3 && !q.LaCauNhom)
            </MudChip>
        </div>
    </div>

    @* ── Câu hỏi đơn ── *@
    @if (FilteredSingles.Count > 0)
    {
        <div class="d-flex align-center gap-2 mb-2">
            <MudText Typo="Typo.subtitle1" Style="font-weight:600">Câu hỏi đơn</MudText>
            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled">@FilteredSingles.Count</MudChip>
        </div>

        <MudDataGrid Items="FilteredSingles" Hover="true" Dense="true" SortMode="SortMode.None"
                     Class="mb-5 rounded-lg" Elevation="2">
            <Columns>
                <PropertyColumn Property="x => x.MaSoCauHoi" Title="STT" Style="width:64px" />
                <TemplateColumn Title="Nội dung" CellStyle="max-width:480px">
                    <CellTemplate>
                        <MudTooltip Text="@(context.Item.NoiDung ?? "")" Placement="Placement.Right" MaxWidth="MaxWidth.Medium">
                            <MudText Typo="Typo.body2" Style="white-space:normal">
                                @Truncate(context.Item.NoiDung ?? "", 120)
                            </MudText>
                        </MudTooltip>
                        @RenderMedia(context.Item.Files)
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Đáp án đúng" Style="width:200px">
                    <CellTemplate>
                        @{
                            var correct = context.Item.CauTraLois.FirstOrDefault(a => a.LaDapAn);
                            string label = correct is null
                                ? "—"
                                : $"{"ABCD"[correct.ThuTu - 1]}. {Truncate(correct.NoiDung ?? "", 40)}";
                        }
                        <MudText Typo="Typo.body2" Color="Color.Success">@label</MudText>
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Cấp độ" Style="width:90px">
                    <CellTemplate>
                        <MudChip T="string" Size="Size.Small" Color="@CapDoColor(context.Item.CapDo)">
                            @CapDoLabel(context.Item.CapDo)
                        </MudChip>
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="" Style="width:120px">
                    <CellTemplate>
                        <MudTooltip Text="Xem trước">
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                           Size="Size.Small" Color="Color.Info"
                                           OnClick="() => OpenPreviewDialog(context.Item)" />
                        </MudTooltip>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Size="Size.Small" Color="Color.Primary"
                                       OnClick="() => OpenEditDialog(context.Item)" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Size="Size.Small" Color="Color.Error"
                                       OnClick="() => DeleteAsync(context.Item.MaCauHoi)" />
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>
    }

    @* ── Câu hỏi nhóm ── *@
    @if (FilteredGroups.Count > 0)
    {
        <div class="d-flex align-center gap-2 mb-2">
            <MudText Typo="Typo.subtitle1" Style="font-weight:600">Câu hỏi nhóm</MudText>
            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">@FilteredGroups.Count nhóm</MudChip>
        </div>

        <MudExpansionPanels MultiExpansion="true" Class="mb-4 rounded-lg" Elevation="2">
            @foreach (var grp in FilteredGroups)
            {
                <MudExpansionPanel>
                    <TitleContent>
                        <div class="d-flex align-center gap-3" style="width:100%">
                            <MudText Typo="Typo.body2" Style="min-width:40px;font-weight:600">
                                #@grp.MaSoCauHoi
                            </MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Class="mr-1">
                                @grp.SoCauHoiCon câu con
                            </MudChip>
                            <MudChip T="string" Size="Size.Small" Color="@CapDoColor(grp.CapDo)">
                                @CapDoLabel(grp.CapDo)
                            </MudChip>
                            @if (grp.Files.Any(f => f.LoaiFile == 1))
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Image" Size="Size.Small" Color="Color.Info" Title="Có hình ảnh" />
                            }
                            @if (grp.Files.Any(f => f.LoaiFile == 2))
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Audiotrack" Size="Size.Small" Color="Color.Secondary" Title="Có âm thanh" />
                            }
                            <MudTooltip Text="@(grp.NoiDung ?? "")" Placement="Placement.Right" MaxWidth="MaxWidth.Medium">
                                <MudText Typo="Typo.body2" Class="flex-grow-1" Style="white-space:normal">
                                    @Truncate(grp.NoiDung ?? "", 100)
                                </MudText>
                            </MudTooltip>
                            <span @onclick:stopPropagation="true" class="d-flex gap-1">
                                <MudTooltip Text="Xem trước">
                                    <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                                   Size="Size.Small" Color="Color.Info"
                                                   OnClick="@(() => OpenPreviewDialog(grp))" />
                                </MudTooltip>
                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                               Size="Size.Small" Color="Color.Primary"
                                               OnClick="@(() => OpenEditDialog(grp))" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Size="Size.Small" Color="Color.Error"
                                               OnClick="@(() => DeleteAsync(grp.MaCauHoi))" />
                            </span>
                        </div>
                    </TitleContent>
                    <ChildContent>
                        @RenderMedia(grp.Files)

                        @if (grp.CauHoiCons.Count == 0)
                        {
                            <MudText Typo="Typo.body2" Class="mud-text-secondary pa-2">
                                Không có câu hỏi con.
                            </MudText>
                        }
                        else
                        {
                            <MudTable Items="grp.CauHoiCons" Dense="true" Hover="true"
                                      Elevation="0" Style="background:transparent">
                                <HeaderContent>
                                    <MudTh Style="width:48px">Câu</MudTh>
                                    <MudTh>Nội dung</MudTh>
                                    <MudTh Style="width:200px">Đáp án đúng</MudTh>
                                    <MudTh Style="width:90px">Cấp độ</MudTh>
                                    <MudTh Style="width:48px"></MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd>@(grp.CauHoiCons.IndexOf(context) + 1)</MudTd>
                                    <MudTd>
                                        <MudTooltip Text="@(context.NoiDung ?? "")" Placement="Placement.Right">
                                            <MudText Typo="Typo.body2" Style="white-space:normal">
                                                @Truncate(context.NoiDung ?? "", 120)
                                            </MudText>
                                        </MudTooltip>
                                        @RenderMedia(context.Files)
                                    </MudTd>
                                    <MudTd>
                                        @{
                                            var ca = context.CauTraLois.FirstOrDefault(a => a.LaDapAn);
                                            string ca_label = ca is null
                                                ? "—"
                                                : $"{"ABCD"[ca.ThuTu - 1]}. {Truncate(ca.NoiDung ?? "", 40)}";
                                        }
                                        <MudText Typo="Typo.body2" Color="Color.Success">@ca_label</MudText>
                                    </MudTd>
                                    <MudTd>
                                        <MudChip T="string" Size="Size.Small" Color="@CapDoColor(context.CapDo)">
                                            @CapDoLabel(context.CapDo)
                                        </MudChip>
                                    </MudTd>
                                    <MudTd>
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                       Size="Size.Small" Color="Color.Primary"
                                                       OnClick="() => OpenEditDialog(context)" />
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                    </ChildContent>
                </MudExpansionPanel>
            }
        </MudExpansionPanels>
    }
}

@if (_lightboxUrl != null)
{
    <div style="position:fixed;top:0;left:0;width:100vw;height:100vh;background:rgba(0,0,0,0.88);z-index:9999;display:flex;align-items:center;justify-content:center;cursor:zoom-out"
         @onclick="() => _lightboxUrl = null">
        <img src="@_lightboxUrl"
             style="max-width:90vw;max-height:90vh;object-fit:contain;border-radius:8px;box-shadow:0 8px 40px rgba(0,0,0,.6)"
             @onclick:stopPropagation />
    </div>
}

@code {
    List<MonHocDto> _monHocList = [];
    List<PhanDto>   _phanList   = [];
    List<CauHoiDto> _questions  = [];

    Guid    _maMonHoc    = Guid.Empty;
    Guid    _maPhan      = Guid.Empty;
    bool    _loading     = false;
    string? _lightboxUrl;
    string  _searchText  = "";
    int     _filterCapDo = 0;

    List<CauHoiDto> FilteredSingles => _questions
        .Where(q => !q.LaCauNhom)
        .Where(q => _filterCapDo == 0 || q.CapDo == _filterCapDo)
        .Where(q => string.IsNullOrWhiteSpace(_searchText) || (q.NoiDung ?? "").Contains(_searchText, StringComparison.OrdinalIgnoreCase))
        .ToList();

    List<CauHoiDto> FilteredGroups => _questions
        .Where(q => q.LaCauNhom)
        .Where(q => _filterCapDo == 0 || q.CapDo == _filterCapDo)
        .Where(q => string.IsNullOrWhiteSpace(_searchText) || (q.NoiDung ?? "").Contains(_searchText, StringComparison.OrdinalIgnoreCase))
        .ToList();

    protected override async Task OnInitializedAsync()
        => _monHocList = await MonHocService.GetAllAsync();

    private async Task OnMonHocChanged(Guid maMonHoc)
    {
        _maMonHoc  = maMonHoc;
        _maPhan    = Guid.Empty;
        _questions = [];
        _phanList  = maMonHoc != Guid.Empty
            ? await PhanService.GetAllByMonHocAsync(maMonHoc)
            : [];
    }

    private async Task OnPhanChanged(Guid maPhan)
    {
        _maPhan = maPhan;
        _searchText  = "";
        _filterCapDo = 0;
        await LoadQuestionsAsync();
    }

    private void SetFilter(int capDo) => _filterCapDo = capDo;

    private async Task LoadQuestionsAsync()
    {
        if (_maPhan == Guid.Empty) { _questions = []; return; }
        _loading = true;
        try   { _questions = await CauHoiService.GetByPhanAsync(_maPhan); }
        finally { _loading = false; }
    }

    private async Task OpenImportDialog()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog  = await DialogService.ShowAsync<ImportWordDialog>("Import câu hỏi từ file", options);
        var result  = await dialog.Result;
        if (result is { Canceled: false })
            await LoadQuestionsAsync();
    }

    private async Task OpenMediaDialog()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        await DialogService.ShowAsync<MediaUploadDialog>("Quản lý Media", options);
    }

    private async Task OpenPreviewDialog(CauHoiDto cauHoi)
    {
        var parameters = new DialogParameters<PreviewCauHoiDialog>
        {
            { x => x.CauHoi, cauHoi }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        await DialogService.ShowAsync<PreviewCauHoiDialog>("Xem trước câu hỏi", parameters, options);
    }

    private async Task OpenEditDialog(CauHoiDto cauHoi)
    {
        var parameters = new DialogParameters<EditCauHoiDialog>
        {
            { x => x.CauHoi, cauHoi }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var title   = cauHoi.LaCauNhom ? "Chỉnh sửa câu nhóm" : "Chỉnh sửa câu hỏi";
        var dialog  = await DialogService.ShowAsync<EditCauHoiDialog>(title, parameters, options);
        var result  = await dialog.Result;
        if (result is { Canceled: false })
            await LoadQuestionsAsync();
    }

    private RenderFragment RenderMedia(List<FileDinhKemDto> files) => builder =>
    {
        var images = files.Where(f => f.LoaiFile == 1).ToList();
        var audios = files.Where(f => f.LoaiFile == 2).ToList();

        int seq = 0;
        if (images.Count > 0)
        {
            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "class", "d-flex flex-wrap gap-1 mt-1");
            foreach (var img in images)
            {
                builder.OpenElement(seq++, "img");
                builder.AddAttribute(seq++, "src", img.Url);
                builder.AddAttribute(seq++, "alt", img.TenFile);
                builder.AddAttribute(seq++, "style", "max-height:80px;max-width:120px;object-fit:contain;border:1px solid #ddd;border-radius:4px;cursor:zoom-in");
                builder.AddAttribute(seq++, "onclick", EventCallback.Factory.Create<Microsoft.AspNetCore.Components.Web.MouseEventArgs>(this, () => _lightboxUrl = img.Url));
                builder.CloseElement();
            }
            builder.CloseElement();
        }

        foreach (var audio in audios)
        {
            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "class", "mt-1");
            builder.OpenElement(seq++, "audio");
            builder.AddAttribute(seq++, "controls", true);
            builder.AddAttribute(seq++, "style", "height:36px;max-width:280px");
            builder.OpenElement(seq++, "source");
            builder.AddAttribute(seq++, "src", audio.Url);
            builder.CloseElement();
            builder.CloseElement();
            builder.CloseElement();
        }
    };

    private async Task DeleteAsync(Guid id)
    {
        var q = _questions.FirstOrDefault(x => x.MaCauHoi == id);
        string msg = q?.LaCauNhom == true
            ? $"Xóa nhóm này sẽ xóa cả {q.SoCauHoiCon} câu con. Tiếp tục?"
            : "Bạn có chắc muốn xóa câu hỏi này?";

        bool? confirmed = await DialogService.ShowMessageBoxAsync("Xác nhận xóa", msg,
            yesText: "Xóa", cancelText: "Hủy");

        if (confirmed == true)
        {
            await CauHoiService.DeleteAsync(id);
            Snackbar.Add("Đã xóa.", Severity.Success);
            await LoadQuestionsAsync();
        }
    }

    private static string Truncate(string s, int max)
        => s.Length <= max ? s : s[..max] + "…";

    private static Color CapDoColor(short cap) => cap switch
    {
        1 => Color.Success,
        2 => Color.Warning,
        _ => Color.Error
    };

    private static string CapDoLabel(short cap) => cap switch
    {
        1 => "Dễ",
        2 => "TB",
        _ => "Khó"
    };
}

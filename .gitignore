## ============================================================
##  .gitignore cho dự án Blazor Web App (.NET) - QuestionBank
## ============================================================

# ---------------------------------------------------------------
# Build output
# ---------------------------------------------------------------
[Bb]in/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/

# ---------------------------------------------------------------
# Visual Studio
# ---------------------------------------------------------------
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs

# ---------------------------------------------------------------
# AI Tools
# ---------------------------------------------------------------
.claude/

# Visual Studio cache / options directory
.vs/
# Uncomment if you need Razor pages compiled output
# **/obj/Debug/net*/

# ---------------------------------------------------------------
# .NET / MSBuild
# ---------------------------------------------------------------
project.lock.json
project.fragment.lock.json
artifacts/

# NuGet packages
*.nupkg
*.snupkg
**/[Pp]ackages/
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# NuGet local cache
.nuget/

# ---------------------------------------------------------------
# Blazor / ASP.NET Core
# ---------------------------------------------------------------
# Compiled Razor views
**/obj/
**/bin/

# Static web assets manifest (auto-generated)
staticwebassets.build.json
staticwebassets.development.json

# ---------------------------------------------------------------
# Sensitive configuration (KHÔNG commit thông tin nhạy cảm!)
# ---------------------------------------------------------------
appsettings.Development.json
appsettings.Local.json
appsettings.*.local.json
**/secrets.json
**/*.pfx
**/*.p12
**/*.key
**/*.pem

# Nếu dùng User Secrets của .NET
%APPDATA%\Microsoft\UserSecrets\

# ---------------------------------------------------------------
# Entity Framework Core
# ---------------------------------------------------------------
# Không bỏ Migrations vào gitignore - cần commit migrations!
# Chỉ bỏ snapshot tạm nếu cần

# ---------------------------------------------------------------
# Rider / JetBrains
# ---------------------------------------------------------------
.idea/
*.sln.iml
_ReSharper*/
*.DotSettings.user

# ---------------------------------------------------------------
# macOS
# ---------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*

# ---------------------------------------------------------------
# Windows
# ---------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ---------------------------------------------------------------
# Node.js (nếu dự án có frontend tools như npm/webpack)
# ---------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn/
dist/
.parcel-cache/

# ---------------------------------------------------------------
# Docker (nếu có)
# ---------------------------------------------------------------
.dockerignore

# ---------------------------------------------------------------
# Test / Coverage
# ---------------------------------------------------------------
TestResults/
coverage/
*.trx
*.coverage
*.coveragexml
*.opencover.xml

# BenchmarkDotNet output
BenchmarkDotNet.Artifacts/

# ---------------------------------------------------------------
# Môi trường / CI
# ---------------------------------------------------------------
.env
.env.local
.env.*.local

# ---------------------------------------------------------------
# Publish output
# ---------------------------------------------------------------
publish/
**/publish/

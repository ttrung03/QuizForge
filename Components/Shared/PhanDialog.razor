@using MudBlazor
@using QuestionBank.Web.Application.DTOs
@using QuestionBank.Web.Application.Services
@inject PhanService PhanService
@inject MonHocService MonHocService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(ExistingPhan == null ? Icons.Material.Filled.Add : Icons.Material.Filled.Edit)"
                     Class="mr-2" />
            @(ExistingPhan == null ? "Thêm Phần mới" : "Chỉnh sửa Phần")
        </MudText>
    </TitleContent>

    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudSelect @bind-Value="_model.MaMonHoc"
                       Label="Môn học"
                       Required="true"
                       RequiredError="Vui lòng chọn môn học"
                       Variant="Variant.Outlined"
                       Class="mt-2">
                @foreach (var monHoc in _monHocList)
                {
                    <MudSelectItem Value="@monHoc.MaMonHoc">@monHoc.TenMonHoc</MudSelectItem>
                }
            </MudSelect>

            <MudTextField @bind-Value="_model.TenPhan"
                          Label="Tên Phần"
                          Placeholder="Ví dụ: Phần I - Kiến thức cơ bản"
                          Required="true"
                          RequiredError="Vui lòng nhập tên phần"
                          MaxLength="250"
                          Counter="250"
                          Immediate="true"
                          Variant="Variant.Outlined"
                          Class="mt-3" />

            <MudTextField @bind-Value="_model.NoiDung"
                          Label="Nội dung"
                          Placeholder="Mô tả nội dung của phần"
                          Lines="3"
                          MaxLength="500"
                          Counter="500"
                          Immediate="true"
                          Variant="Variant.Outlined"
                          Class="mt-3" />

        </MudForm>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Hủy</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="_saving"
                   OnClick="Submit">
            @if (_saving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Đang lưu...</span>
            }
            else
            {
                <span>Lưu</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    /// <summary>
    /// null  → đang thêm mới
    /// có giá trị → đang chỉnh sửa, form sẽ điền sẵn dữ liệu cũ
    /// </summary>
    [Parameter] public PhanDto? ExistingPhan { get; set; }
    [Parameter] public Guid MaMonHoc { get; set; }

    MudForm _form    = default!;
    bool    _isValid = false;
    bool    _saving  = false;

    List<MonHocDto> _monHocList = new();
    SavePhanDto _model          = new();

    protected override async Task OnInitializedAsync()
    {
        _monHocList = await MonHocService.GetAllAsync();

        if (ExistingPhan != null)
        {
            _model.MaPhan        = ExistingPhan.MaPhan;
            _model.MaMonHoc      = ExistingPhan.MaMonHoc;
            _model.TenPhan       = ExistingPhan.TenPhan;
            _model.NoiDung       = ExistingPhan.NoiDung;
            _model.MaPhanCha     = ExistingPhan.MaPhanCha;
            _model.MaSoPhan      = ExistingPhan.MaSoPhan;
        }
        else
        {
            _model.MaMonHoc = MaMonHoc;
        }
    }

    async Task Submit()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid) return;

        _saving = true;
        try
        {
            await PhanService.SaveAsync(_model);
            Snackbar.Add("Lưu thành công!", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Lỗi: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    void Cancel() => MudDialog.Cancel();
}

@using Microsoft.AspNetCore.Components.Routing
@using MudBlazor

<MudNavMenu Class="pa-2">

    <MudNavLink Href="/"
                Match="NavLinkMatch.All"
                Icon="@Icons.Material.Filled.Dashboard">
        Trang chủ
    </MudNavLink>

    <MudDivider Class="my-2" />

    <MudText Typo="Typo.overline" Class="px-3 mud-text-secondary" Style="font-size:.65rem;letter-spacing:.08em">
        DANH MỤC
    </MudText>

    <MudNavGroup Title="Danh mục"
                 Icon="@Icons.Material.Filled.Category"
                 Expanded="false">
        <MudNavLink Href="/danhmuc/khoa"        Icon="@Icons.Material.Outlined.School">Quản lý Khoa</MudNavLink>
        <MudNavLink Href="/danhmuc/monhoc"      Icon="@Icons.Material.Outlined.Book">Quản lý Môn học</MudNavLink>
        <MudNavLink Href="/danhmuc/khoa-monhoc" Icon="@Icons.Material.Outlined.AccountBalance">Khoa &amp; Môn học</MudNavLink>
        <MudNavLink Href="/danhmuc/phan"        Icon="@Icons.Material.Outlined.AccountTree">Quản lý Phần/Chương</MudNavLink>
    </MudNavGroup>

    <MudDivider Class="my-2" />

    <MudText Typo="Typo.overline" Class="px-3 mud-text-secondary" Style="font-size:.65rem;letter-spacing:.08em">
        NỘI DUNG
    </MudText>

    <MudNavLink Href="/cauhoi" Icon="@Icons.Material.Filled.Quiz">
        Ngân hàng Câu hỏi
    </MudNavLink>

    <MudNavLink Href="/dethi" Icon="@Icons.Material.Filled.Assignment">
        Quản lý Đề thi
    </MudNavLink>

</MudNavMenu>

@inherits LayoutComponentBase
@using MudBlazor

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>

    <!-- ── AppBar trên cùng ──────────────────────────────────────────────── -->
    <MudAppBar Color="Color.Primary" Fixed="true" Elevation="4">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-2">Ngân Hàng Câu Hỏi Trắc Nghiệm</MudText>
        <MudSpacer />
        <MudText Typo="Typo.body2" Class="mud-text-secondary">v1.0</MudText>
    </MudAppBar>

    <!-- ── Sidebar ───────────────────────────────────────────────────────── -->
    <MudDrawer @bind-Open="_drawerOpen" Elevation="1" ClipMode="DrawerClipMode.Always">
        <MudDrawerHeader>
            <MudText Typo="Typo.subtitle1" Class="fw-bold">Menu chính</MudText>
        </MudDrawerHeader>
        <NavMenu />
    </MudDrawer>

    <!-- ── Nội dung chính ────────────────────────────────────────────────── -->
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 mb-8">
            @Body
        </MudContainer>
    </MudMainContent>

</MudLayout>

@code {
    bool _drawerOpen = true;
    void ToggleDrawer() => _drawerOpen = !_drawerOpen;
}

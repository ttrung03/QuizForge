@inherits LayoutComponentBase
@using MudBlazor

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>

    <!-- ── AppBar ──────────────────────────────────────────────────────────── -->
    <MudAppBar Color="Color.Primary" Fixed="true" Elevation="4" Dense="false">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="ToggleDrawer" />
        <MudIcon Icon="@Icons.Material.Filled.MenuBook" Color="Color.Inherit" Class="ml-1 mr-2" />
        <MudText Typo="Typo.h6" Style="font-weight:600;letter-spacing:.3px">
            Ngân Hàng Câu Hỏi Trắc Nghiệm
        </MudText>
        <MudSpacer />
        <MudChip T="string" Size="Size.Small" Color="Color.Default"
                 Icon="@Icons.Material.Filled.Verified"
                 Style="opacity:.85">v1.0</MudChip>
    </MudAppBar>

    <!-- ── Sidebar ─────────────────────────────────────────────────────────── -->
    <MudDrawer @bind-Open="_drawerOpen" Elevation="2" ClipMode="DrawerClipMode.Always"
               Style="border-right:1px solid var(--mud-palette-divider)">
        <MudDrawerHeader Class="d-flex align-center gap-2 py-3"
                         Style="background:linear-gradient(135deg,#1e40af 0%,#3b82f6 100%)">
            <MudIcon Icon="@Icons.Material.Filled.School" Color="Color.Surface" Size="Size.Medium" />
            <div>
                <MudText Typo="Typo.subtitle2" Style="color:#fff;font-weight:700;line-height:1.2">
                    QuestionBank
                </MudText>
                <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,.7);line-height:1">
                    Quản lý câu hỏi
                </MudText>
            </div>
        </MudDrawerHeader>
        <NavMenu />
    </MudDrawer>

    <!-- ── Nội dung chính ──────────────────────────────────────────────────── -->
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 mb-8">
            @Body
        </MudContainer>
    </MudMainContent>

</MudLayout>

@code {
    bool _drawerOpen = true;
    void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary         = "#2563EB",
            PrimaryDarken   = "#1D4ED8",
            PrimaryLighten  = "#3B82F6",
            Secondary       = "#7C3AED",
            Tertiary        = "#0891B2",
            AppbarBackground = "#1E40AF",
            DrawerBackground = "#F8FAFC",
            DrawerText       = "#1E293B",
            Background       = "#F1F5F9",
            Surface          = "#FFFFFF",
            TextPrimary      = "#0F172A",
            TextSecondary    = "#64748B",
            Divider          = "#E2E8F0",
            TableLines       = "#E2E8F0",
            OverlayDark      = "rgba(15,23,42,.6)",
        }
    };
}
